{
  "annotations": {
    "list": []
  },
  "description": "Admission webhook performance metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Top 10 Webhook Admission Latency",
      "description": "Average latency for the 10 slowest webhooks over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(10, rate(apiserver_admission_webhook_admission_duration_seconds_sum{name=~\"$webhook_filter\"}[5m]) / rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Webhook Overhead Per Request",
      "description": "Sum of all matched webhook latencies — the total admission delay added to each API request",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(apiserver_admission_webhook_admission_duration_seconds_sum{name=~\"$webhook_filter\", type=\"validating\"}[5m]) / (rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\", type=\"validating\"}[5m]) > 0))",
          "legendFormat": "Validating total",
          "refId": "A"
        },
        {
          "expr": "sum(rate(apiserver_admission_webhook_admission_duration_seconds_sum{name=~\"$webhook_filter\", type=\"admit\"}[5m]) / (rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\", type=\"admit\"}[5m]) > 0))",
          "legendFormat": "Mutating total",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Total API Request Duration (including admission)",
      "description": "P99 end-to-end API request duration for pod/deployment create and update operations",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apiserver_request_duration_seconds_bucket{resource=~\"pods|deployments\", subresource=\"\", verb=~\"POST|PUT|CREATE|UPDATE|PATCH\"}[5m])))",
          "legendFormat": "P99 all create/update",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(apiserver_request_duration_seconds_bucket{resource=~\"pods|deployments\", subresource=\"\", verb=~\"POST|PUT|CREATE|UPDATE|PATCH\"}[5m])))",
          "legendFormat": "P50 all create/update",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Webhook Calls (5m window)",
      "description": "Total webhook calls in the last 5 minutes",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\", type=\"validating\"}[5m]))",
          "legendFormat": "Validating calls",
          "refId": "A"
        },
        {
          "expr": "sum(increase(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\", type=\"admit\"}[5m]))",
          "legendFormat": "Mutating calls",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Webhook Rejections (5m window)",
      "description": "Total webhook rejections in the last 5 minutes",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(increase(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\", rejected=\"true\"}[5m])) or vector(0)",
          "legendFormat": "Rejections",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Top 10 Rejecting Webhooks",
      "description": "Which webhooks rejected the most requests over the dashboard time range",
      "type": "bargauge",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "expr": "topk(10, sum by (name) (increase(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"$webhook_filter\", rejected=\"true\"}[$__range])))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["webhook", "admission", "performance", "openshift"],
  "templating": {
    "list": [
      {
        "name": "webhook_filter",
        "label": "Webhooks",
        "type": "custom",
        "current": {
          "text": "webhook-perf-test only",
          "value": "webhook-perf-.*"
        },
        "options": [
          {
            "text": "webhook-perf-test only",
            "value": "webhook-perf-.*",
            "selected": true
          },
          {
            "text": "All cluster webhooks",
            "value": ".*",
            "selected": false
          }
        ],
        "query": "webhook-perf-.* : webhook-perf-test only, .* : All cluster webhooks"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Webhook Performance",
  "uid": "webhook-perf-test",
  "version": 4
}
