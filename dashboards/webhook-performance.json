{
  "annotations": {
    "list": []
  },
  "description": "Admission webhook performance metrics for webhook-perf-test",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Per-Webhook Admission Latency",
      "description": "Average latency per webhook over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(apiserver_admission_webhook_admission_duration_seconds_sum{name=~\"webhook-perf-.*\"}[5m]) / rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\"}[5m])",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Admission Step Duration",
      "description": "Combined duration of all webhooks in each admission step",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(apiserver_admission_step_admission_duration_seconds_sum{type=\"validate\"}[5m]) / rate(apiserver_admission_step_admission_duration_seconds_count{type=\"validate\"}[5m])",
          "legendFormat": "Validating",
          "refId": "A"
        },
        {
          "expr": "rate(apiserver_admission_step_admission_duration_seconds_sum{type=\"mutate\"}[5m]) / rate(apiserver_admission_step_admission_duration_seconds_count{type=\"mutate\"}[5m])",
          "legendFormat": "Mutating",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Total API Request Duration (including admission)",
      "description": "End-to-end API request duration showing the total impact of webhooks on request time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, resource) (rate(apiserver_request_duration_seconds_bucket{resource=~\"pods|deployments\", subresource=\"\", verb=~\"POST|PUT|CREATE|UPDATE\"}[5m])))",
          "legendFormat": "P99 {{resource}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, resource) (rate(apiserver_request_duration_seconds_bucket{resource=~\"pods|deployments\", subresource=\"\", verb=~\"POST|PUT|CREATE|UPDATE\"}[5m])))",
          "legendFormat": "P50 {{resource}}",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Webhook Call Rate",
      "description": "Admission webhook calls per second",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Webhook Server CPU Usage vs Limit",
      "description": "CPU utilization of webhook server pods compared to their configured limit",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU Limit" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"webhook-perf-test\", container=\"webhook-server\"}[5m]))",
          "legendFormat": "CPU Usage ({{pod}})",
          "refId": "A"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_resource_limits{namespace=\"webhook-perf-test\", container=\"webhook-server\", resource=\"cpu\"})",
          "legendFormat": "CPU Limit",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Webhook Rejections",
      "description": "Webhook rejection rate over time and total count",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "stacking": { "mode": "normal" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum by (name) (rate(apiserver_admission_webhook_rejection_count{name=~\"webhook-perf-.*\"}[5m])) or vector(0)",
          "legendFormat": "{{name}} (rejections)",
          "refId": "A"
        },
        {
          "expr": "sum by (name) (rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\", rejected=\"true\"}[5m])) or vector(0)",
          "legendFormat": "{{name}} (rejected)",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["webhook", "admission", "performance", "openshift"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Webhook Performance",
  "uid": "webhook-perf-test",
  "version": 2
}
