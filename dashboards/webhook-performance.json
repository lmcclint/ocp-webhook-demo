{
  "annotations": {
    "list": []
  },
  "description": "Admission webhook performance metrics for webhook-perf-test",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Top 10 Webhook Admission Latency",
      "description": "Average latency for the 10 slowest webhooks over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "topk(10, rate(apiserver_admission_webhook_admission_duration_seconds_sum{name=~\"webhook-perf-.*\"}[5m]) / rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\"}[5m]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Admission Step Duration",
      "description": "Combined duration of all webhooks in each admission step",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(apiserver_admission_step_admission_duration_seconds_sum{type=\"validate\"}[5m]) / rate(apiserver_admission_step_admission_duration_seconds_count{type=\"validate\"}[5m])",
          "legendFormat": "Validating",
          "refId": "A"
        },
        {
          "expr": "rate(apiserver_admission_step_admission_duration_seconds_sum{type=\"mutate\"}[5m]) / rate(apiserver_admission_step_admission_duration_seconds_count{type=\"mutate\"}[5m])",
          "legendFormat": "Mutating",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Total API Request Duration (including admission)",
      "description": "P99 end-to-end API request duration for pod/deployment create and update operations",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apiserver_request_duration_seconds_bucket{resource=~\"pods|deployments\", subresource=\"\", verb=~\"POST|PUT|CREATE|UPDATE|PATCH\"}[5m])))",
          "legendFormat": "P99 all create/update",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(apiserver_request_duration_seconds_bucket{resource=~\"pods|deployments\", subresource=\"\", verb=~\"POST|PUT|CREATE|UPDATE|PATCH\"}[5m])))",
          "legendFormat": "P50 all create/update",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Webhook Call Rate (total)",
      "description": "Total admission webhook calls per second across all webhook-perf webhooks",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\", type=\"validating\"}[5m]))",
          "legendFormat": "Validating calls/s",
          "refId": "A"
        },
        {
          "expr": "sum(rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\", type=\"admit\"}[5m]))",
          "legendFormat": "Mutating calls/s",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Webhook Rejections",
      "description": "Total webhook rejection rate over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "decimals": 0,
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(apiserver_admission_webhook_rejection_count{name=~\"webhook-perf-.*\"}[5m])) or vector(0)",
          "legendFormat": "Rejections/s (legacy metric)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(apiserver_admission_webhook_admission_duration_seconds_count{name=~\"webhook-perf-.*\", rejected=\"true\"}[5m])) or vector(0)",
          "legendFormat": "Rejections/s",
          "refId": "B"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["webhook", "admission", "performance", "openshift"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Webhook Performance",
  "uid": "webhook-perf-test",
  "version": 3
}
